  44          //
  45          void I2CSendByte(unsigned char byt)
  46          {
  47   1          unsigned char i;
  48   1        
  49   1          for(i=0; i<8; i++){
  50   2              scl = 0;
  51   2          I2C_Delay(DELAY_TIME);
