 498   1        uchar val = 0xff,VAL_P3 = 0,VAL_P44 = 0,VAL_P42 = 0;
 499   1        VAL_P3 = P3;VAL_P44 = P44;VAL_P42 = P42;
 500   1        val = (VAL_P3&0x0f)|(VAL_P44<<7)|(VAL_P42<<6);
 501   1        return val;
 502   1      }
