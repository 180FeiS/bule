   9          #include <reg52.h>
  10          #include <intrins.h>
  11          sbit SCK = P1^7;
  12          sbit SDA = P2^3;
  13          sbit RST = P1^3;
  14          unsigned int  time_ds[3] = {5,3,13};
  15          
  16          void Write_Ds1302(unsigned  char temp) 
  17          {
  18   1        unsigned char i;
  19   1        for (i=0;i<8;i++)       
  20   1        { 
  21   2          SCK = 0;
  22   2          SDA = temp&0x01;
  23   2          temp>>=1; 
  24   2          SCK=1;
  25   2        }
  26   1      }   
  27          
  28          //
  29          void Write_Ds1302_Byte( unsigned char address,unsigned char dat )     
  30          {
  31   1        RST=0;  _nop_();
  32   1        SCK=0;  _nop_();
  33   1        RST=1;  _nop_();  
  34   1        Write_Ds1302(address);  
  35   1        Write_Ds1302(dat);    
  36   1        RST=0; 
  37   1      }
  38          
  39          //
  40          unsigned char Read_Ds1302_Byte ( unsigned char address )
  41          {
  42   1        unsigned char i,temp=0x00;
  43   1        RST=0;  _nop_();
  44   1        SCK=0;  _nop_();
  45   1        RST=1;  _nop_();
  46   1        Write_Ds1302(address);
  47   1        for (i=0;i<8;i++)   
  48   1        {   
  49   2          SCK=0;
  50   2          temp>>=1; 
  51   2          if(SDA)
  52   2          temp|=0x80; 
  53   2          SCK=1;
C51 COMPILER V9.60.0.0   DS1302                                                            04/05/2025 17:42:13 PAGE 2   

  54   2        } 
  55   1        RST=0;  _nop_();
  56   1        SCK=0;  _nop_();
  57   1        SCK=1;  _nop_();
  58   1        SDA=0;  _nop_();
  59   1        SDA=1;  _nop_();
  60   1        return (temp);      
  61   1      }
  62          
  63          void time_init()
  64          {
  65   1        unsigned char i,add;
  66   1        add = 0x80;
  67   1        Write_Ds1302_Byte(0x8e,0x00);
  68   1        for(i=0;i<3;i++)
  69   1        {
  70   2          Write_Ds1302_Byte(add,(time_ds[i]/10)<<4|time_ds[i]%10);
  71   2          add+=2;
  72   2        }
  73   1        Write_Ds1302_Byte(0x8e,0x80);
  74   1      }
  75          
  76          void time_get()
  77          {
  78   1        unsigned char i,dat,add;
  79   1        add = 0x81;
  80   1        for(i=0;i<3;i++)
  81   1        {
  82   2          dat = Read_Ds1302_Byte(add);
  83   2          time_ds[i] = dat/16*10+dat%16;
  84   2          add+=2;
  85   2        }
  86   1      }


