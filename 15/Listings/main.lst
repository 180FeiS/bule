 502          void key_w(uchar val)
 503          {
 504   1        uchar value = val;
 505   1        P30 = (value&0x01);P31 = (value&0x02)>>1;P32 = (value&0x04)>>2;P33 = (value&0x08)>>3;
 506   1        P44 = (value>>7);P42 = (value&0x40)>>6;
 507   1      }
 508          unsigned char key_r()
 509          {
 510   1        uchar val = 0xff,VAL_P3 = 0,VAL_P44 = 0,VAL_P42 = 0;
 511   1        VAL_P3 = P3;VAL_P44 = P44;VAL_P42 = P42;
 512   1        val = ((VAL_P3&0x0f)|(VAL_P44<<7)|(VAL_P42<<6));
 513   1        return val;
 514   1      }
